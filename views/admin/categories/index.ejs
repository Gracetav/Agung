<div class="py-12">
    <div class="mb-10">
        <a href="/admin/dashboard" class="inline-flex items-center gap-4 bg-white border-2 border-gray-100 text-gray-900 px-8 py-4 rounded-2xl font-black text-sm uppercase shadow-sm hover:border-blue-600 hover:text-blue-600 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
            </svg>
            Kembali ke Dashboard
        </a>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Manajemen Kategori</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Total <%= categories.length %> Kategori Tersedia</p>
        </div>
        <a href="/admin/categories/create" class="gradient-blue text-white px-10 py-5 rounded-3xl font-black text-sm uppercase shadow-xl shadow-blue-200 hover:scale-105 transition-all flex items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Tambah Kategori
        </a>
    </div>

    <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100">
        <div class="overflow-x-auto p-8">
            <table class="w-full text-left font-medium">
                <thead>
                    <tr class="text-sm font-black text-blue-600 uppercase tracking-widest border-b-4 border-blue-600/20">
                        <th class="py-8 px-6">ID</th>
                        <th class="py-8 px-6">Nama Kategori</th>
                        <th class="py-8 px-6">Slug/URL</th>
                        <th class="py-8 px-6">Status</th>
                        <th class="py-8 px-6 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% categories.forEach(cat => { %>
                        <tr class="hover:bg-blue-50/20 transition-all group">
                            <td class="py-8 px-6 font-black text-gray-400">#<%= cat.id %></td>
                            <td class="py-8 px-6 font-black text-gray-900 text-lg group-hover:text-blue-600 transition-colors"><%= cat.name %></td>
                            <td class="py-8 px-6 font-bold text-gray-400"><%= cat.slug %></td>
                            <td class="py-8 px-6">
                                <span class="px-5 py-2 rounded-full font-black text-[10px] uppercase tracking-widest <%= cat.is_active ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-gray-100 text-gray-400' %>">
                                    <%= cat.is_active ? 'Active' : 'Hidden' %>
                                </span>
                            </td>
                            <td class="py-8 px-6">
                                <div class="flex items-center justify-center gap-4">
                                    <a href="/admin/categories/edit/<%= cat.id %>" class="p-4 bg-blue-50 text-blue-600 rounded-2xl hover:bg-blue-600 hover:text-white transition-all shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <button onclick="deleteCategory(<%= cat.id %>)" class="p-4 bg-rose-50 text-rose-600 rounded-2xl hover:bg-rose-600 hover:text-white transition-all shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function deleteCategory(id) {
    Swal.fire({
        title: 'Hapus Kategori?',
        text: "Kategori ini akan terhapus, pastikan tidak ada produk yang menggunakannya!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e11d48',
        cancelButtonColor: '#2563eb',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal'
    }).then((result) => {
        if (result.isConfirmed) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/admin/categories/delete/${id}`;
            document.body.appendChild(form);
            form.submit();
        }
    })
}
</script>
