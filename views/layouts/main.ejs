<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bengkel Agung Sparepart Sejahtera - <%= typeof title !== 'undefined' ? title : '' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Swiper.js -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        .gradient-blue { background: linear-gradient(135deg, #2563eb, #0891b2); }
        .hero-banner { background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1542362567-b05503f3ac56?auto=format&fit=crop&q=80&w=2070'); background-size: cover; background-position: center; }
        
        .swiper { width: 100%; height: 100%; border-radius: 1.5rem; }
        .swiper-slide { display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; color: white; border-radius: 1.5rem; overflow: hidden; }
        .slide-1 { background: linear-gradient(rgba(8, 145, 178, 0.5), rgba(37, 99, 235, 0.7)), url('https://images.unsplash.com/photo-1558981403-c5f91cbba527?auto=format&fit=crop&q=80&w=2070'); background-size: cover; background-position: center; }
        .slide-2 { background: linear-gradient(rgba(37, 99, 235, 0.5), rgba(8, 145, 178, 0.7)), url('https://images.unsplash.com/photo-1449495169669-7b118f960237?auto=format&fit=crop&q=80&w=2070'); background-size: cover; background-position: center; }
        .slide-3 { background: linear-gradient(rgba(8, 145, 178, 0.4), rgba(37, 99, 235, 0.6)), url('https://images.unsplash.com/photo-1485291571150-772bcfc10da5?auto=format&fit=crop&q=80&w=2128'); background-size: cover; background-position: center; }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 bg-white shadow-lg border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20">
                <!-- Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex flex-col">
                        <span class="text-2xl font-bold text-blue-600 tracking-tight">Agung Sparepart</span>
                        <span class="text-xs uppercase tracking-widest text-cyan-600 font-semibold">Sejahtera</span>
                    </a>
                </div>

                <!-- Desktop Menu -->
                <div class="hidden md:flex items-center space-x-8">
                    <a href="/" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Katalog</a>
                    
                    <% if (user && user.role === 'admin') { %>
                        <a href="/admin/dashboard" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Admin Dashboard</a>
                        <a href="/auth/logout" class="bg-red-50 text-red-600 px-5 py-2.5 rounded-full font-semibold transition-all hover:bg-red-100">Logout</a>
                    <% } else if (user) { %>
                        <a href="/user/orders" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Pesanan Saya</a>
                        <a href="/user/cart" class="relative group">
                            <span class="p-2.5 bg-blue-50 text-blue-600 rounded-full group-hover:bg-blue-100 transition-all flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                <span class="font-bold"><%= cartCount %></span>
                            </span>
                        </a>
                        <div class="flex items-center gap-4 pl-4 border-l">
                            <span class="text-sm font-semibold text-gray-800">Halo, <%= user.name %>!</span>
                            <a href="/auth/logout" class="bg-red-50 text-red-600 px-5 py-2.5 rounded-full font-semibold transition-all hover:bg-red-100">Logout</a>
                        </div>
                    <% } else { %>
                        <a href="/auth/login" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Masuk</a>
                        <a href="/auth/register" class="gradient-blue text-white px-8 py-3 rounded-full font-bold shadow-lg shadow-blue-200 transition-all hover:scale-105 active:scale-95">Daftar</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Flash Messages -->
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="mb-6 animate-fade-in flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-700 px-6 py-4 rounded-2xl shadow-sm">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="font-medium"><%= success_msg %></span>
                </div>
            <% } %>
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="mb-6 animate-fade-in flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-700 px-6 py-4 rounded-2xl shadow-sm">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <span class="font-medium"><%= error_msg %></span>
                </div>
            <% } %>
            
            <%- body %>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12 mt-auto border-t-4 border-blue-600">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center md:text-left">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <div>
                  <h3 class="text-3xl font-bold text-white mb-2">Agung Sparepart</h3>
                  <p class="text-gray-400 font-medium">Solusi Terpercaya untuk Kebutuhan Motor Anda.</p>
                </div>
                <div class="flex justify-center md:justify-end gap-12 font-medium">
                    <p class="text-gray-400">&copy; 2026 Bengkel Agung Sejahtera. Semua Hak Dilindungi.</p>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
