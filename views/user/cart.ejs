<div class="max-w-7xl mx-auto mb-10">
    <a href="/" class="inline-flex items-center gap-4 bg-white border-2 border-gray-100 text-gray-900 px-8 py-4 rounded-2xl font-black text-sm uppercase shadow-sm hover:border-blue-600 hover:text-blue-600 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
        </svg>
        Kembali ke Katalog
    </a>
</div>
<div class="max-w-7xl mx-auto py-12 md:py-24 px-6 bg-white rounded-3xl shadow-xl overflow-hidden mb-12">
    <h1 class="text-3xl md:text-5xl font-black text-gray-900 mb-12 tracking-tight">Keranjang Belanja</h1>

    <% if (cart && cart.length > 0) { %>
        <div class="overflow-x-auto border-2 border-gray-100 rounded-3xl p-8 bg-gray-50/50">
            <table class="w-full text-left font-medium">
                <thead>
                    <tr class="text-sm font-black text-blue-600 uppercase tracking-widest border-b-4 border-blue-600/20">
                        <th class="py-8 px-6">Produk</th>
                        <th class="py-8 px-6">Harga</th>
                        <th class="py-8 px-6">Jumlah</th>
                        <th class="py-8 px-6">Subtotal</th>
                        <th class="py-8 px-6 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% let total = 0; %>
                    <% cart.forEach(item => { %>
                        <% total += item.price * item.qty; %>
                        <tr class="hover:bg-blue-50/50 transition-colors group">
                            <td class="py-10 px-6 flex items-center gap-8">
                                <div class="w-24 h-24 bg-white rounded-2xl border-2 border-gray-100 shadow-sm overflow-hidden flex-shrink-0">
                                    <% if (item.image) { %>
                                        <img src="/uploads/products/<%= item.image %>" class="w-full h-full object-cover">
                                    <% } %>
                                </div>
                                <span class="font-black text-gray-900 text-xl group-hover:text-blue-600 transition-colors"><%= item.name %></span>
                            </td>
                            <td class="py-10 px-6 font-black text-gray-600">Rp <%= item.price.toLocaleString() %></td>
                            <td class="py-10 px-6">
                                <form action="/user/cart/update" method="POST" class="flex items-center gap-4 border-2 border-gray-300 rounded-2xl overflow-hidden bg-white shadow-inner max-w-min">
                                    <input type="hidden" name="productId" value="<%= item.id %>">
                                    <input type="number" name="qty" value="<%= item.qty %>" min="1" class="w-20 px-4 py-3 text-center font-black focus:outline-none">
                                    <button type="submit" class="bg-blue-600 text-white px-6 py-3 font-black text-xs uppercase hover:bg-blue-700 transition-colors">Update</button>
                                </form>
                            </td>
                            <td class="py-10 px-6 font-black text-blue-600 text-xl">Rp <%= (item.price * item.qty).toLocaleString() %></td>
                            <td class="py-10 px-6 text-center">
                                <button onclick="confirmRemove(<%= item.id %>)" class="p-4 bg-rose-50 text-rose-600 rounded-full hover:bg-rose-100 transition-all inline-flex items-center justify-center shadow-sm">
                                   <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                   </svg>
                                 </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="mt-16 flex flex-col md:flex-row justify-end items-center gap-12 border-t-2 border-gray-100 pt-16">
            <div class="text-right">
                <p class="text-sm font-black text-gray-500 uppercase tracking-widest mb-2">Total Pembayaran</p>
                <p class="text-5xl font-black text-blue-600">Rp <%= total.toLocaleString() %></p>
            </div>
            
            <form action="/user/checkout" method="POST" class="w-full md:w-auto flex flex-col items-center md:items-end gap-6">
                <div class="w-full max-w-md">
                    <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-3 pr-2">Alamat Pengiriman Lengkap</label>
                    <textarea name="shipping_address" required class="w-full bg-gray-50 border-2 border-gray-200 rounded-2xl p-6 text-sm font-bold focus:border-blue-500 transition-all outline-none" placeholder="Masukkan alamat lengkap pengiriman anda..." rows="3"></textarea>
                </div>
                <button type="submit" class="w-full md:w-auto gradient-blue text-white px-20 py-8 rounded-3xl font-black text-2xl shadow-xl shadow-blue-200 hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-6">
                    Checkout Sekarang
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </button>
            </form>
        </div>
    <% } else { %>
        <div class="text-center py-24 bg-gray-50/50 rounded-3xl border-2 border-dashed border-gray-200">
            <div class="mb-10 text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
            </div>
            <h2 class="text-3xl font-black text-gray-900 mb-4 tracking-tight">Keranjang Anda Kosong</h2>
            <p class="text-gray-500 font-medium mb-12">Sepertinya Anda belum memilih suku cadang apa pun.</p>
            <a href="/" class="gradient-blue text-white px-12 py-5 rounded-full font-bold shadow-lg shadow-blue-200 inline-flex items-center gap-4 hover:scale-105 transition-all text-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
                Kembali Belanja
            </a>
        </div>
    <% } %>
</div>

<script>
function confirmRemove(id) {
    Swal.fire({
        title: 'Hapus dari Keranjang?',
        text: "Anda dapat menambahkannya kembali nanti.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e11d48',
        cancelButtonColor: '#2563eb',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/user/cart/remove/${id}`;
        }
    })
}
</script>
