<div class="min-h-[80vh] flex items-center justify-center py-12 px-6">
    <div class="w-full max-w-lg space-y-12 bg-white p-16 rounded-[40px] shadow-2xl border border-gray-100 group">
        <div class="text-center">
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter group-hover:text-blue-600 transition-colors">Daftar Akun Baru</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Bergabung dengan Kami Sekarang</p>
        </div>
        
        <form class="space-y-10" action="/auth/register" method="POST">
            <div class="space-y-10">
                <div class="relative">
                    <label for="name" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Nama Lengkap</label>
                    <input id="name" name="name" type="text" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Nama Anda">
                </div>
                <div class="relative">
                    <label for="email" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Email</label>
                    <input id="email" name="email" type="email" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Email@anda.com">
                </div>
                <div class="relative">
                    <label for="password" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Password</label>
                    <input id="password" name="password" type="password" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="********">
                </div>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full gradient-blue text-white py-6 rounded-3xl font-black text-xl shadow-xl shadow-blue-200 hover:scale-[1.02] active:scale-95 transition-all text-center flex items-center justify-center gap-6 group">
                    Daftar Akun
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 group-hover:translate-x-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                </button>
            </div>
        </form>
        
        <div class="text-center pt-8 border-t-2 border-gray-50">
            <p class="text-lg font-bold text-gray-500">
                Sudah punya akun? 
                <a href="/auth/login" class="text-blue-600 font-black hover:underline underline-offset-8 decoration-4 transition-all">Login di Sini</a>
            </p>
        </div>
    </div>
</div>
