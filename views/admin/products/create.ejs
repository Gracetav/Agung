<div class="py-12 max-w-4xl mx-auto">
    <div class="mb-10">
        <a href="/admin/products" class="inline-flex items-center gap-4 bg-white border-2 border-gray-100 text-gray-900 px-8 py-4 rounded-2xl font-black text-sm uppercase shadow-sm hover:border-blue-600 hover:text-blue-600 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
            </svg>
            Kembali ke Daftar Produk
        </a>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Tambah Produk Baru</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Masukkan Detail Suku Cadang Original</p>
        </div>
    </div>

    <form action="/admin/products/create" method="POST" enctype="multipart/form-data" class="bg-white p-16 rounded-[40px] shadow-2xl space-y-12 border border-gray-100">
        <div class="space-y-10">
            <div class="relative group">
                <label for="name" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Nama Produk</label>
                <input id="name" name="name" type="text" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Contoh: Oli Yamalube Sport">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="relative group">
                    <label for="price" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Harga (Rp)</label>
                    <input id="price" name="price" type="number" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="0">
                </div>
                <div class="relative group">
                    <label for="stock" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Stok Awal</label>
                    <input id="stock" name="stock" type="number" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="0">
                </div>
                <div class="relative group">
                    <label for="category_id" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Kategori Suku Cadang</label>
                    <select id="category_id" name="category_id" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner appearance-none uppercase">
                        <option value="">-- Pilih Kategori --</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.id %>"><%= cat.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="relative group">
                    <label for="tipekendaraan" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Tipe Kendaraan</label>
                    <input id="tipekendaraan" name="tipekendaraan" type="text" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Contoh: Matic, Manual">
                </div>
            </div>

            <div class="relative group">
                <label for="description" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Deskripsi Produk</label>
                <textarea id="description" name="description" rows="5" class="w-full px-10 py-8 border-2 border-gray-100 rounded-4xl text-lg font-medium text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Jelaskan detail spesifikasi produk..."></textarea>
            </div>

            <div class="relative group">
                <label class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Foto Produk</label>
                <div class="bg-gray-50 p-8 rounded-4xl border-2 border-dashed border-gray-200 group-hover:border-blue-300 transition-all cursor-pointer relative overflow-hidden">
                    <input type="file" name="image" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10">
                    <div class="text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <p class="text-sm font-bold text-gray-500 uppercase">Klik atau Seret file ke sini</p>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mt-2">Max 5MB (JPG/PNG)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="pt-10 flex gap-8">
            <a href="/admin/products" class="flex-1 px-10 py-6 border-2 border-gray-100 text-gray-900 rounded-3xl font-black text-lg text-center hover:bg-gray-50 transition-all uppercase tracking-widest">Batal</a>
            <button type="submit" class="flex-[2] gradient-blue text-white py-6 rounded-3xl font-black text-xl shadow-xl shadow-blue-200 hover:scale-[1.02] active:scale-95 transition-all text-center flex items-center justify-center gap-6 group">
                Simpan Produk
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 group-hover:translate-y-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
            </button>
        </div>
    </form>
</div>
