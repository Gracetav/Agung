<div class="py-12 max-w-4xl mx-auto">
    <div class="mb-10">
        <a href="/admin/categories" class="inline-flex items-center gap-4 bg-white border-2 border-gray-100 text-gray-900 px-8 py-4 rounded-2xl font-black text-sm uppercase shadow-sm hover:border-blue-600 hover:text-blue-600 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
            </svg>
            Kembali ke Daftar Kategori
        </a>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Tambah Kategori</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Klasifikasikan Suku Cadang Anda</p>
        </div>
    </div>

    <form action="/admin/categories/create" method="POST" class="bg-white p-16 rounded-[40px] shadow-2xl space-y-12 border border-gray-100">
        <div class="space-y-10">
            <div class="relative group">
                <label for="name" class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4 block px-6">Nama Kategori</label>
                <input id="name" name="name" type="text" required class="w-full px-10 py-6 border-2 border-gray-100 rounded-3xl text-lg font-black text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-600 transition-all bg-gray-50 shadow-inner" placeholder="Contoh: Oli & Pelumas">
            </div>
        </div>

        <div class="pt-10 flex gap-8">
            <a href="/admin/categories" class="flex-1 px-10 py-6 border-2 border-gray-100 text-gray-900 rounded-3xl font-black text-lg text-center hover:bg-gray-50 transition-all uppercase tracking-widest">Batal</a>
            <button type="submit" class="flex-[2] gradient-blue text-white py-6 rounded-3xl font-black text-xl shadow-xl shadow-blue-200 hover:scale-[1.02] active:scale-95 transition-all text-center flex items-center justify-center gap-6 group">
                Simpan Kategori
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 group-hover:translate-y-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
            </button>
        </div>
    </form>
</div>
