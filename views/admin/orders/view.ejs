<div class="py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Detail Transaksi #<%= order.id %></h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Pelanggan: <%= order.user_name %> (<%= new Date(order.created_at).toLocaleDateString() %>)</p>
        </div>
        <div class="flex items-center gap-4">
            <a href="/admin/orders" class="p-5 text-gray-400 hover:text-blue-600 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
            </a>
            <% if (order.status === 'pending') { %>
                <span class="px-10 py-5 bg-amber-50 text-amber-700 text-lg font-black uppercase tracking-widest rounded-full border-2 border-amber-200">Menunggu Pembayaran</span>
            <% } else if (order.status === 'paid') { %>
                <span class="px-10 py-5 bg-emerald-50 text-emerald-700 text-lg font-black uppercase tracking-widest rounded-full border-2 border-emerald-200">Pembayaran Terverifikasi</span>
            <% } else if (order.status === 'shipped') { %>
                <span class="px-10 py-5 bg-blue-50 text-blue-700 text-lg font-black uppercase tracking-widest rounded-full border-2 border-blue-200">Sedang Dikirim</span>
            <% } else if (order.status === 'completed') { %>
                <span class="px-10 py-5 bg-indigo-50 text-indigo-700 text-lg font-black uppercase tracking-widest rounded-full border-2 border-indigo-200">Pesanan Selesai</span>
            <% } else { %>
                <span class="px-10 py-5 bg-rose-50 text-rose-700 text-lg font-black uppercase tracking-widest rounded-full border-2 border-rose-200">Pesanan Ditolak</span>
            <% } %>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 items-start">
        <!-- Order Items & Items Summary -->
        <div class="lg:col-span-2 space-y-16">
            <div class="bg-white rounded-[40px] shadow-2xl p-12 border border-blue-50 border-t-8 border-t-blue-600 overflow-hidden">
                <table class="w-full text-left font-medium">
                    <thead>
                        <tr class="text-sm font-black text-blue-600 uppercase tracking-widest border-b-4 border-blue-50 pb-8">
                            <th class="py-6 px-4">Informasi Produk</th>
                            <th class="py-6 px-4 text-center">Harga Jual</th>
                            <th class="py-6 px-4 text-center">Jumlah</th>
                            <th class="py-6 px-4 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% items.forEach(item => { %>
                            <tr class="group hover:bg-gray-50/50 transition-all">
                                <td class="py-8 px-4 flex items-center gap-6">
                                    <div class="w-20 h-20 bg-gray-50 rounded-2xl overflow-hidden border border-gray-100 flex-shrink-0 animate-pulse-slow">
                                        <% if (item.image) { %>
                                            <img src="/uploads/products/<%= item.image %>" class="w-full h-full object-cover">
                                        <% } %>
                                    </div>
                                    <span class="font-black text-gray-900 text-lg group-hover:text-blue-600 transition-colors"><%= item.name %></span>
                                </td>
                                <td class="py-8 px-4 text-center font-bold text-gray-600 tracking-tighter">Rp <%= item.price.toLocaleString() %></td>
                                <td class="py-8 px-4 text-center font-black text-gray-900 text-xl tracking-tighter"><%= item.qty %></td>
                                <td class="py-8 px-4 text-right font-black text-blue-700 text-2xl tracking-tighter">Rp <%= (item.price * item.qty).toLocaleString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <div class="mt-12 flex justify-end border-t-4 border-blue-50 pt-12 items-center gap-10">
                    <h3 class="text-xl font-bold text-gray-400 uppercase tracking-widest">Total Bayar:</h3>
                    <p class="text-5xl font-black text-blue-700 tracking-tighter">Rp <%= order.total_price.toLocaleString() %></p>
                </div>
            </div>

            <!-- Admin Actions -->
            <div class="bg-gray-900 rounded-[40px] shadow-3xl p-12 text-white relative overflow-hidden group">
                <div class="relative z-10">
                    <h3 class="text-3xl font-black mb-8 border-b-2 border-white/10 pb-6 flex items-center gap-4">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                      </svg>
                      KONTROL PESANAN
                    </h3>
                    <div class="flex flex-wrap gap-6 items-center">
                        <form action="/admin/orders/<%= order.id %>/status" method="POST" class="flex flex-wrap gap-6 items-center">
                            <button type="submit" name="status" value="paid" class="px-10 py-5 bg-emerald-600 text-white rounded-3xl font-black text-sm uppercase shadow-xl hover:bg-emerald-700 hover:scale-105 active:scale-95 transition-all text-center flex items-center gap-4 border-b-4 border-emerald-800">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Konfirmasi Pembayaran
                            </button>
                            <button type="submit" name="status" value="shipped" class="px-10 py-5 bg-blue-600 text-white rounded-3xl font-black text-sm uppercase shadow-xl hover:bg-blue-700 hover:scale-105 active:scale-95 transition-all text-center flex items-center gap-4 border-b-4 border-blue-800">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                                Kirim Barang
                            </button>
                            <button type="submit" name="status" value="completed" class="px-10 py-5 bg-indigo-600 text-white rounded-3xl font-black text-sm uppercase shadow-xl hover:bg-indigo-700 hover:scale-105 active:scale-95 transition-all text-center flex items-center gap-4 border-b-4 border-indigo-800">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                </svg>
                                Selesaikan Pesanan
                            </button>
                            <button type="submit" name="status" value="rejected" class="px-10 py-5 bg-rose-600 text-white rounded-3xl font-black text-sm uppercase shadow-xl hover:bg-rose-700 hover:scale-105 active:scale-95 transition-all text-center flex items-center gap-4 border-b-4 border-rose-800">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Batalkan (Reject)
                            </button>
                        </form>
                    </div>
                    <p class="mt-12 text-sm font-bold text-gray-400 uppercase tracking-widest italic flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Pastikan Anda telah mengecek bukti transfer pelanggan sebelum menekan tombol konfirmasi.
                    </p>
                </div>
                <div class="absolute -right-20 -top-20 opacity-5 group-hover:rotate-12 transition-transform duration-1000">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-96 w-96 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Payment Evidence Section -->
        <div class="sticky top-28 bg-white p-12 rounded-[40px] shadow-2xl border border-gray-100 flex flex-col items-center">
            <h3 class="text-2xl font-black text-gray-900 mb-10 w-full border-b pb-6 flex items-center gap-4 self-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
              BUKTI PEMBAYARAN
            </h3>
            
            <% if (payment) { %>
                <div class="w-full space-y-10 group">
                    <div class="relative overflow-hidden rounded-3xl shadow-xl border-4 border-gray-50 p-2 bg-white">
                        <img src="/uploads/payments/<%= payment.proof %>" class="w-full h-auto object-cover rounded-2xl transition-transform duration-500 group-hover:scale-[1.5] cursor-zoom-in" alt="Bukti Transfer">
                    </div>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center text-sm font-black text-gray-500 uppercase tracking-widest border-b pb-4">
                            <span>Waktu Upload</span>
                            <span class="text-gray-900"><%= new Date(payment.created_at).toLocaleTimeString() %></span>
                        </div>
                        <div class="flex justify-between items-center text-sm font-black text-gray-500 uppercase tracking-widest border-b pb-4">
                            <span>Status Bukti</span>
                            <span class="bg-blue-50 text-blue-600 px-4 py-1 rounded-full border border-blue-100">DITERIMA</span>
                        </div>
                    </div>
                    <a href="/uploads/payments/<%= payment.proof %>" target="_blank" class="block w-full py-5 text-center text-blue-600 font-black text-sm uppercase tracking-widest hover:underline hover:bg-blue-50/50 rounded-2xl transition-all">
                        Lihat Gambar Penuh
                    </a>
                </div>
            <% } else { %>
                <div class="text-center py-20 bg-gray-50/50 w-full rounded-4xl border-2 border-dashed border-gray-200">
                    <div class="mb-8 text-gray-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <p class="text-lg font-black text-gray-500 tracking-tight mb-4">BELUM ADA BUKTI</p>
                    <p class="text-xs font-bold text-gray-400 px-10 leading-relaxed uppercase tracking-widest">MENUNGGU USER UNTUK MENGUNGGAH FOTO TRANSAKSI.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
