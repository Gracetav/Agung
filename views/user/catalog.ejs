<!-- Hero Carousel Section -->
<section class="h-[400px] md:h-[550px] mb-16 rounded-[40px] overflow-hidden shadow-2xl relative">
  <div class="swiper mySwiper w-full h-full">
    <div class="swiper-wrapper">
      <!-- Slide 1 -->
      <div class="swiper-slide slide-1 px-8">
        <h1 class="text-4xl md:text-7xl font-black mb-6 tracking-tighter drop-shadow-2xl">Performa Motor <br><span class="text-cyan-300">Tanpa Batas</span></h1>
        <p class="text-blue-50 text-xl font-bold max-w-2xl mb-12 opacity-95">Dapatkan sparepart original terbaik untuk performa maksimal kendaraan kesayangan Anda.</p>
        <a href="#products" class="bg-white text-blue-700 px-12 py-5 rounded-full font-black shadow-2xl hover:scale-105 transition-all text-lg">Mulai Belanja</a>
      </div>
      <!-- Slide 2 -->
      <div class="swiper-slide slide-2 px-8">
        <h1 class="text-4xl md:text-7xl font-black mb-6 tracking-tighter drop-shadow-2xl">Layanan <br><span class="text-blue-300">Terpercaya</span></h1>
        <p class="text-blue-50 text-xl font-bold max-w-2xl mb-12 opacity-95">Bengkel Agung Sejahtera mengedepankan kualitas dan keaslian produk demi kepuasan pelanggan.</p>
        <a href="#products" class="bg-white text-blue-700 px-12 py-5 rounded-full font-black shadow-2xl hover:scale-105 transition-all text-lg">Cek Katalog</a>
      </div>
      <!-- Slide 3 -->
      <div class="swiper-slide slide-3 px-8">
        <h1 class="text-4xl md:text-7xl font-black mb-6 tracking-tighter drop-shadow-2xl">Harga <br><span class="text-cyan-300">Bersaing</span></h1>
        <p class="text-blue-50 text-xl font-bold max-w-2xl mb-12 opacity-95">Kami menyediakan suku cadang motor original dengan harga yang sangat kompetitif di pasaran.</p>
        <a href="#products" class="bg-white text-blue-700 px-12 py-5 rounded-full font-black shadow-2xl hover:scale-105 transition-all text-lg">Tunggu Apa Lagi?</a>
      </div>
    </div>
    <!-- Swiper Pagination/Navigation -->
    <div class="swiper-pagination"></div>
    <div class="swiper-button-next !text-white !opacity-50 hover:!opacity-100 transition-opacity"></div>
    <div class="swiper-button-prev !text-white !opacity-50 hover:!opacity-100 transition-opacity"></div>
  </div>
</section>

<!-- Swiper Initialization -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var swiper = new Swiper(".mySwiper", {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
    });
  });
</script>

<!-- Product List -->
<div id="products" class="py-12">
    <!-- Filters -->
    <div class="mb-16 p-10 bg-white rounded-4xl border-2 border-gray-100 shadow-xl">
        <form action="/" method="GET" class="flex flex-wrap gap-8 items-end">
            <div class="flex-grow min-w-[300px]">
                <label class="block text-[10px] font-black text-blue-600 uppercase tracking-widest mb-3 pr-2">Search Spareparts</label>
                <input type="text" name="search" value="<%= query.search || '' %>" placeholder="What part do you need?" class="w-full bg-gray-50 border-none rounded-2xl px-8 py-5 text-sm font-bold focus:ring-4 focus:ring-blue-500/20 outline-none transition-all">
            </div>
            <div class="w-64">
                <label class="block text-[10px] font-black text-blue-600 uppercase tracking-widest mb-3 pr-2">By Category</label>
                <select name="category" class="w-full bg-gray-50 border-none rounded-2xl px-8 py-5 text-xs font-black uppercase tracking-widest outline-none appearance-none focus:ring-4 focus:ring-blue-500/20 transition-all">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= query.category == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="flex gap-4">
                <button type="submit" class="bg-blue-600 text-white px-10 py-5 rounded-2xl font-black text-[10px] uppercase shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all">Filter</button>
                <a href="/" class="bg-gray-100 text-gray-400 px-10 py-5 rounded-2xl font-black text-[10px] uppercase hover:bg-gray-200 transition-all">Reset</a>
            </div>
        </form>
    </div>

    <div class="flex justify-between items-end mb-12">
        <div>
            <h2 class="text-3xl font-extrabold text-gray-900 mb-2 uppercase tracking-tighter">Available <span class="text-blue-600">Inventory</span></h2>
            <div class="h-1.5 w-24 bg-blue-600 rounded-full"></div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
        <% products.forEach(product => { %>
            <div class="group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 border border-gray-100 flex flex-col hover:-translate-y-2 <%= product.stock <= 0 ? 'opacity-60 grayscale-[0.5]' : '' %>">
                <!-- Product Image -->
                <div class="aspect-square bg-gray-100 relative overflow-hidden">
                    <% if (product.stock <= 0) { %>
                        <div class="absolute inset-0 bg-black/40 z-20 flex items-center justify-center backdrop-blur-sm">
                            <span class="bg-rose-600 text-white px-8 py-3 rounded-full font-black text-[10px] uppercase tracking-widest shadow-2xl">Stok Habis</span>
                        </div>
                    <% } %>
                    <% if (product.image) { %>
                        <img src="/uploads/products/<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-gray-400 bg-gray-200">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                        </div>
                    <% } %>
                    <div class="absolute top-4 right-4 <%= product.stock > 0 ? 'animate-pulse' : '' %>">
                        <span class="<%= product.stock > 0 ? 'bg-blue-600' : 'bg-gray-400' %> text-white text-[10px] uppercase font-black px-4 py-1.5 rounded-full shadow-lg">
                            <%= product.stock > 0 ? 'Ready Stock' : 'Out of Stock' %>
                        </span>
                    </div>
                </div>

                <!-- Product Info -->
                <div class="p-6 md:p-8 flex-grow flex flex-col">
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2 mb-3 uppercase tracking-tight"><%= product.name %></h3>
                    <% if(product.category_name) { %>
                        <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-4"><%= product.category_name %> | <%= product.tipekendaraan || 'All-Terrain' %></p>
                    <% } %>
                    <p class="text-sm font-medium text-gray-500 line-clamp-2 mb-6"><%= product.description || 'Kualitas terjamin untuk performa motor Anda' %></p>
                    
                    <div class="mt-auto">
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-2xl font-black text-blue-600">Rp <%= product.price.toLocaleString() %></span>
                        </div>
                        <% if(product.stock > 0) { %>
                            <a href="/products/<%= product.id %>" class="mt-6 w-full gradient-blue text-white py-4 rounded-2xl font-bold text-sm text-center shadow-lg shadow-blue-100 hover:shadow-blue-200 transition-all flex items-center justify-center group-hover:scale-[1.02]">
                                Lihat Detail
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </a>
                        <% } else { %>
                            <button disabled class="mt-6 w-full bg-gray-200 text-gray-400 py-4 rounded-2xl font-bold text-sm text-center cursor-not-allowed">Stok Kosong</button>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
</div>
