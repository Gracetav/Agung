<div class="py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Manajemen Pelanggan</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Total <%= users.length %> Pengguna Terdaftar</p>
        </div>
    </div>

    <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100 p-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left font-medium">
                <thead>
                    <tr class="text-sm font-black text-blue-600 uppercase tracking-widest border-b-4 border-blue-600/20">
                        <th class="py-8 px-6">User ID</th>
                        <th class="py-8 px-6">Informasi Pelanggan</th>
                        <th class="py-8 px-6">Detail Kontak</th>
                        <th class="py-8 px-6 text-center">Status</th>
                        <th class="py-8 px-6 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% users.forEach(user => { %>
                        <tr class="hover:bg-blue-50/20 transition-all group">
                            <td class="py-10 px-6 font-black text-gray-400">#<%= user.id %></td>
                            <td class="py-10 px-6">
                                <div class="flex items-center gap-6">
                                    <div class="h-16 w-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center font-black text-2xl group-hover:bg-blue-600 group-hover:text-white transition-all shadow-lg shadow-blue-50">
                                        <%= user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-black text-gray-900 text-xl"><%= user.name %></span>
                                        <span class="text-xs font-bold text-blue-600 uppercase tracking-widest mt-1">Role: Pelanggan</span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-10 px-6 font-bold text-gray-500">
                                <p class="text-sm font-black text-gray-900 mb-1"><%= user.email %></p>
                                <p class="text-[10px] uppercase tracking-widest opacity-60">Verified Account</p>
                            </td>
                            <td class="py-10 px-6 text-center">
                                <% if(user.is_active) { %>
                                    <span class="bg-emerald-100 text-emerald-600 px-4 py-2 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-emerald-200">Active</span>
                                <% } else { %>
                                    <span class="bg-red-100 text-red-600 px-4 py-2 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-red-200">Inactive</span>
                                <% } %>
                            </td>
                            <td class="py-10 px-6 text-center flex items-center justify-center gap-4">
                                <a href="/admin/users/toggle/<%= user.id %>" class="p-5 font-black text-xs uppercase rounded-2xl transition-all shadow-sm hover:scale-105 active:scale-95 <%= user.is_active ? 'bg-orange-50 text-orange-600' : 'bg-emerald-50 text-emerald-600' %>">
                                    <%= user.is_active ? 'Deactivate' : 'Activate' %>
                                </a>
                                <button onclick="deleteUser(<%= user.id %>)" class="p-5 bg-rose-50 text-rose-600 rounded-2xl hover:bg-rose-600 hover:text-white transition-all shadow-sm hover:scale-110 active:scale-95 group">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 group-hover:animate-shake" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function deleteUser(id) {
    Swal.fire({
        title: 'Hapus User?',
        text: "Semua data pesanan user ini juga akan terhapus!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e11d48',
        cancelButtonColor: '#2563eb',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal'
    }).then((result) => {
        if (result.isConfirmed) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/admin/users/delete/${id}`;
            document.body.appendChild(form);
            form.submit();
        }
    })
}
</script>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
