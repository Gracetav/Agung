<div class="py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-10">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter">Manajemen Pesanan</h1>
            <p class="text-xl font-bold text-gray-500 uppercase tracking-widest opacity-80">Pantau Seluruh Transaksi Pelanggan</p>
        </div>
    </div>

    <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100">
        <div class="overflow-x-auto p-8">
            <table class="w-full text-left font-medium">
                <thead>
                    <tr class="text-sm font-black text-blue-600 uppercase tracking-widest border-b-4 border-blue-600/20">
                        <th class="py-8 px-6">Order ID</th>
                        <th class="py-8 px-6">Nama Pelanggan</th>
                        <th class="py-8 px-6">Tanggal Pesanan</th>
                        <th class="py-8 px-6 text-right">Total Transaksi</th>
                        <th class="py-8 px-6 text-center">Status</th>
                        <th class="py-8 px-6 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% orders.forEach(order => { %>
                        <tr class="hover:bg-blue-50/20 transition-all group">
                            <td class="py-8 px-6 font-black text-gray-900 text-lg tracking-tighter">#<%= order.id %></td>
                            <td class="py-10 px-6">
                                <div class="flex flex-col">
                                    <span class="font-black text-gray-900 text-xl group-hover:text-blue-600 transition-colors"><%= order.user_name %></span>
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">ID USER: #<%= order.user_id %></span>
                                </div>
                            </td>
                            <td class="py-8 px-6 font-bold text-gray-500"><%= new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                            <td class="py-8 px-6 font-black text-gray-900 text-right text-xl tracking-tighter">Rp <%= order.total_price.toLocaleString() %></td>
                            <td class="py-8 px-6 text-center">
                                <% if (order.status === 'pending') { %>
                                    <span class="inline-flex items-center gap-2 px-6 py-2 bg-amber-50 text-amber-700 text-sm font-black uppercase tracking-widest rounded-full border border-amber-200 shadow-sm animate-pulse">Menunggu</span>
                                <% } else if (order.status === 'paid') { %>
                                    <span class="inline-flex items-center gap-2 px-6 py-2 bg-emerald-50 text-emerald-700 text-sm font-black uppercase tracking-widest rounded-full border border-emerald-200 shadow-sm">Sudah Bayar</span>
                                <% } else if (order.status === 'shipped') { %>
                                    <span class="inline-flex items-center gap-2 px-6 py-2 bg-blue-50 text-blue-700 text-sm font-black uppercase tracking-widest rounded-full border border-blue-200 shadow-sm">Dikirim</span>
                                <% } else if (order.status === 'completed') { %>
                                    <span class="inline-flex items-center gap-2 px-6 py-2 bg-indigo-50 text-indigo-700 text-sm font-black uppercase tracking-widest rounded-full border border-indigo-200 shadow-sm">Selesai</span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-2 px-6 py-2 bg-rose-50 text-rose-700 text-sm font-black uppercase tracking-widest rounded-full border border-rose-200 shadow-sm">Ditolak</span>
                                <% } %>
                            </td>
                            <td class="py-8 px-6 text-center">
                                <a href="/admin/orders/<%= order.id %>" class="gradient-blue text-white px-8 py-4 rounded-full font-black text-xs uppercase shadow-lg shadow-blue-200 hover:scale-105 transition-all inline-flex items-center gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                    Cek Detail
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
